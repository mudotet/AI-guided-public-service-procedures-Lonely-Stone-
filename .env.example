# Application
NODE_ENV=development
PORT=3000
APP_VERSION=1.0.0

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/applevel
DATABASE_POOL_MAX=100
DATABASE_POOL_MIN=10
DATABASE_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-256-bit-secret-here-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-here-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-key-here-change-in-production

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=applevel-media
R2_REGION=auto

# Evolution API (WhatsApp Integration)
# IMPORTANT: This must be a reachable URL from your application
# Local development options:
#   - External Evolution API: https://evolution.yourdomain.com
#   - Host machine (if Evolution API runs outside Docker): http://host.docker.internal:8080
#   - Docker service (requires adding evolution_api service to docker-compose): http://evolution_api:8080
# Production: Should be a fully qualified domain name (https://evolution.yourdomain.com)
EVOLUTION_API_HOST=https://evolution.example.com
EVOLUTION_API_KEY=your-evolution-api-key

# WhatsApp Notifications (Default instance for system notifications)
# This instance is used to send welcome messages and invitations to new users
WHATSAPP_NOTIFICATION_INSTANCE=system-notifications

# GoHighLevel Integration (Marketplace App OAuth)
# Get these from https://marketplace.gohighlevel.com after creating your app
GHL_CLIENT_ID=your-ghl-client-id-from-marketplace
GHL_CLIENT_SECRET=your-ghl-client-secret-from-marketplace
GHL_REDIRECT_URI=https://api.yourdomain.com/api/v1/ghl/oauth/callback
# APP_URL is used as base for OAuth redirect if GHL_REDIRECT_URI not set
APP_URL=https://api.yourdomain.com

# API Configuration
# IMPORTANT: Must be set to your public domain for webhook callbacks from Evolution API
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://192.168.1.12:5173

# Email (SendGrid - Production)
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=noreply@applevel.com

# SMTP (Mailhog - Development)
# Set USE_SMTP=true to use Mailhog instead of SendGrid in development
USE_SMTP=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Monitoring & Observability
SENTRY_DSN=your-sentry-dsn
SENTRY_TRACES_SAMPLE_RATE=0.1
LOG_LEVEL=info
CORRELATION_ID_HEADER=x-correlation-id

# Alerting
SLACK_WEBHOOK_URL=your-slack-webhook-url
ALERT_WEBHOOK_URL=your-alert-webhook-url
ALERT_EMAIL=alerts@example.com

# Audit Logs
AUDIT_LOG_RETENTION_DAYS=90

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# File Upload
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,audio/mpeg,application/pdf

# Feature Flags
ENABLE_SMS_FALLBACK=true
ENABLE_API_KEYS=true
ENABLE_AUDIT_LOGS=true
ENABLE_METRICS_COLLECTION=true

# Security
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
SESSION_TIMEOUT=3600000
LOCKOUT_ATTEMPTS=5
LOCKOUT_TIME=1800000

# Superadmin (Only one superadmin exists in the system - cannot be removed)
SUPERADMIN_EMAIL=superadmin@applevel.system
SUPERADMIN_PASSWORD=SuperAdmin@2025!SecurePass
SUPERADMIN_FIRST_NAME=Super
SUPERADMIN_LAST_NAME=Admin

GHL_PRODUCT_SYNC_ENABLED=false